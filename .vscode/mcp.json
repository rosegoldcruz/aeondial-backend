{
  "servers": {
    "contextstream": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "--prefer-online",
        "-y",
        "@contextstream/mcp-server@latest"
      ],
      "env": {
        "CONTEXTSTREAM_API_URL": "https://api.contextstream.io",
        "CONTEXTSTREAM_API_KEY": "REDACTED",
        "CONTEXTSTREAM_CONTEXT_PACK": "false"
      }
    }
  }
}
